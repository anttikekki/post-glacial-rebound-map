    "lru-cache": "11.3.5",
    "ol": "10.9.0",
    "proj4": "2.20.8",
    "query-string": "9.3.1",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@types/bootstrap": "5.2.10",
    "copy-webpack-plugin": "14.0.0",
    "css-loader": "7.1.4",
    "html-webpack-plugin": "5.6.7",
    "mini-css-extract-plugin": "2.10.2",
    "npm-check-updates": "22.0.1",
    "style-loader": "4.0.0",
    "ts-loader": "9.5.7",
    "typescript": "6.0.3",
    "webpack": "5.106.2",
